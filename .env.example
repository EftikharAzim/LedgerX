APP_ENV=dev
HTTP_ADDR=:8080

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ledgerx
POSTGRES_USER=ledgerx
POSTGRES_PASSWORD=ledgerx
# for tools on your laptop:
DATABASE_URL_LOCAL=postgres://ledgerx:ledgerx@localhost:5432/ledgerx?sslmode=disable
# for apps inside docker network:
DATABASE_URL_DOCKER=postgres://ledgerx:ledgerx@postgres:5432/ledgerx?sslmode=disable

# Host dev default (make run / make dev). docker-compose overrides this to
# redis:6379 for the containerized API. See deploy/docker-compose.yml.
REDIS_ADDR=localhost:6379
REDIS_DB=0

# REQUIRED outside dev: the API refuses to start without it when APP_ENV != dev
JWT_SIGNING_KEY=change-me-in-prod
API_RATE_LIMIT_RPS=5
# Per-IP limiter on /auth/* (anti credential stuffing). Defaults: 1 rps, burst 10.
#AUTH_RATE_LIMIT_RPS=1
#AUTH_RATE_LIMIT_BURST=10
# Optional: enables POST /admin/snapshot/run (X-Admin-Token header must match).
# Leave unset to disable the endpoint entirely.
#ADMIN_TOKEN=

# Export storage: "local" (default; EXPORT_DIR, dev only) or "s3".
# For s3 set S3_BUCKET (+ S3_ENDPOINT for MinIO/localstack, S3_PREFIX optional)
# and the standard AWS_REGION / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
#EXPORT_STORAGE=local
#EXPORT_DIR=./tmp/exports
#S3_BUCKET=
#S3_ENDPOINT=
#S3_PREFIX=
